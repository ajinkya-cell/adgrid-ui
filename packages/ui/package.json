{
  "name": "@adgrid-ui/ui",
  "version": "0.1.0",
  "description": "Dark-first React component library",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./src/styles/globals.css"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "framer-motion": ">=11",
    "gsap": ">=3",
    "tailwindcss": ">=4"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "framer-motion": "^11.0.0",
    "gsap": "^3.12.0",
    "tailwindcss": "^4.0.0",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.17"
  }
}